# Neo4j Configuration
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
# HTTP: http://localhost:7474
# Bolt: bolt://localhost:7687

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=muscle-rule-engine
